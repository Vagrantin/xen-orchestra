@@ -0,0 +1,53 @@
+diff --git a/@xen-orchestra/lite/scripts/xolite-loader.html b/@xen-orchestra/lite/scripts/xolite-loader.html
+index 9d48835c7..13c73bd31 100644
+--- a/@xen-orchestra/lite/scripts/xolite-loader.html
++++ b/@xen-orchestra/lite/scripts/xolite-loader.html
+@@ -7,23 +7,9 @@
+     <title>XO Lite</title>
+     <script>
+       ;(async () => {
+-        try {
+-          // Try to load XO Lite from lite.xen-orchestra.com
+-          const response = await fetch('https://lite.xen-orchestra.com/dist/index.html')
+-          if (!response.ok) {
+-            throw new Error(`Cannot download XO Lite from lite.xen-orchestra.com (${response.status})`)
+-          }
+-
+-          document.open()
+-          document.write(await response.text())
+-          document.close()
+-        } catch (err) {
+-          console.log(err?.message ?? err)
+-          // Fallback to local version of XO Lite
+           document.open()
+           document.write(await (await fetch('./xolite.html')).text())
+           document.close()
+-        }
+       })()
+     </script>
+   </head>
+diff --git a/@xen-orchestra/lite/src/pages/xoa-deploy.vue b/@xen-orchestra/lite/src/pages/xoa-deploy.vue
+index 26937a4d7..8fac217e3 100644
