++++ b/@xen-orchestra/lite/src/pages/xoa-deploy.vue
+@@ -361,7 +361,7 @@ async function deploy() {
+ 
+     vmRef.value = (
+       (await xapi.call('VM.import', [
+-        'http://xoa.io/xva',
++        'http://192.168.0.1:3000/image.xva',
+         selectedSr.value.$ref,
+         false, // full_restore
+         false, // force
+@@ -371,7 +371,10 @@ async function deploy() {
